# --- Worker/Frontend bundled configuration (Wrangler .dev.vars compatible) ---
#
# For local development:
#   cp example.env .dev.vars
#   # Edit .dev.vars with your actual values
#
# For production:
#   Copy wrangler.prod.toml.example to wrangler.prod.toml and fill in secrets there.
#   (wrangler.prod.toml is gitignored)

# Agent registration shared secret (agents → worker)
# Generate with: openssl rand -base64 32
AGENT_SHARED_SECRET=change-me

# Turnstile (Cloudflare CAPTCHA)
# Get keys at: https://dash.cloudflare.com/?to=/:account/turnstile
# TURNSTILE_SITEKEY is public (shown in frontend)
# TURNSTILE_SECRET is private (server-side verification only)
TURNSTILE_SITEKEY=0x00000000000000000000AAAA
TURNSTILE_SECRET=0x0000000000000000000000000000000AA

# Offline/hidden thresholds (milliseconds)
OFFLINE_AFTER_MS=120000
HIDDEN_AFTER_MS=604800000

# Stalled command detection (ms) — if no chunk/keepalive arrives within this window
STALL_TIMEOUT_MS=20000

# Query runtime guardrail (ms) — worker tells agent; agent enforces
MAX_CMD_RUNTIME_MS=30000

# Rate limiting — Worker-side only (API/binding varies by Cloudflare account feature)
# See worker/src/ratelimit.ts — currently stubbed.
RATE_LIMIT_ENABLED=false

# D1 — in production, Wrangler binds DB via wrangler.toml
# For local dev, Wrangler emulates D1 if configured.